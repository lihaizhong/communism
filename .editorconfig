# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Tab indentation (default to 2 spaces)
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Makefile
[{Makefile,makefile}]
indent_style = tab

# Python files
[*.py]
indent_size = 4

# Shell scripts
[*.{sh,bash}]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Go files
[*.go]
indent_style = tab

# Rust files
[*.rs]
indent_size = 4
