#!/bin/sh
# OpenSpec Validate - Pre-commit Hook
# 在提交前自动运行验证检查

echo "🔍 Running OpenSpec pre-commit validation..."

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 检查是否有未完成的变更需要验证
if [ -d "openspec/changes" ]; then
  CHANGES=$(find openspec/changes -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
  if [ "$CHANGES" -gt 0 ]; then
    echo "📋 Found $CHANGES change(s) in openspec/changes/"
  fi
fi

# 运行 lint
if command -v {{PACKAGE_MANAGER}} >/dev/null 2>&1; then
  echo "🧹 Running linter..."
  {{PACKAGE_MANAGER}} lint
  if [ $? -ne 0 ]; then
    echo "${RED}❌ Lint check failed. Please fix the issues before committing.${NC}"
    exit 1
  fi
  echo "${GREEN}✅ Lint check passed${NC}"
fi

# 运行测试
echo "🧪 Running tests..."
{{PACKAGE_MANAGER}} test
if [ $? -ne 0 ]; then
  echo "${RED}❌ Tests failed. Please fix the failing tests before committing.${NC}"
  exit 1
fi
echo "${GREEN}✅ Tests passed${NC}"

# 运行类型检查（如果有 type-check 命令）
if {{PACKAGE_MANAGER}} run type-check >/dev/null 2>&1; then
  echo "🔎 Running type check..."
  {{PACKAGE_MANAGER}} type-check
  if [ $? -ne 0 ]; then
    echo "${RED}❌ Type check failed. Please fix the type errors before committing.${NC}"
    exit 1
  fi
  echo "${GREEN}✅ Type check passed${NC}"
fi

echo "${GREEN}✨ All validation checks passed!${NC}"
exit 0
