#!/bin/sh
# OpenSpec Validate - Pre-commit Hook
# 在提交前自动运行验证检查

echo "🔍 Running OpenSpec pre-commit validation..."

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 检查是否有未完成的变更需要验证
if [ -d "openspec/changes" ]; then
  CHANGES=$(find openspec/changes -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
  if [ "$CHANGES" -gt 0 ]; then
    echo "📋 Found $CHANGES change(s) in openspec/changes/"
  fi
fi

run_optional_check() {
  LABEL="$1"
  CMD="$2"

  if [ -z "$CMD" ]; then
    return 0
  fi

  echo "🔧 Running ${LABEL}..."
  sh -c "$CMD"
  if [ $? -ne 0 ]; then
    echo "${RED}❌ ${LABEL} failed. Please fix the issues before committing.${NC}"
    exit 1
  fi
  echo "${GREEN}✅ ${LABEL} passed${NC}"
}

run_optional_check "lint" "{{LINT_COMMAND}}"
run_optional_check "tests" "{{TEST_COMMAND}}"
run_optional_check "type/static check" "{{TYPE_CHECK_COMMAND}}"

echo "${GREEN}✨ All validation checks passed!${NC}"
exit 0
