{
  "name": "openspec-opc-workspace",
  "private": true,
  "type": "module",
  "packageManager": "npm@10",
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:opencode && npm run build:codex",
    "build:installer-bundle": "node ./scripts/build-installer-bundle.mjs",
    "benchmark:guard": "npm run build && node ./scripts/benchmark-guard.mjs",
    "preview:demo": "node ./scripts/preview-demo.mjs",
    "build:core": "npm --prefix packages/opc-guard-core run build",
    "build:codex": "npm --prefix plugins/codex-spec-opc run build",
    "build:opencode": "npm --prefix plugins/opencode-spec-opc run build",
    "validate:stages": "node ./install-reference/validate-stages.mjs",
    "test:install-reference": "npm run validate:stages && node --test install-reference/*.test.mjs",
    "test": "npm run test:install-reference && npm run test:preview && npm run test:core && npm --prefix plugins/codex-spec-opc run test && npm --prefix plugins/opencode-spec-opc run test",
    "test:core": "npm --prefix packages/opc-guard-core run test",
    "test:codex": "npm --prefix plugins/codex-spec-opc run test",
    "test:opencode": "npm --prefix plugins/opencode-spec-opc run test",
    "test:preview": "node --test scripts/*.test.mjs",
    "pack:dry-run": "node ./scripts/pack-dry-run.mjs",
    "release:check": "node ./scripts/check-workspace-versions.mjs && npm run validate:stages && npm test && npm run pack:dry-run"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "yaml": "^2.8.3"
  }
}
