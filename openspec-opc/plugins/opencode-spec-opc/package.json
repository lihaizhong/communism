{
  "name": "@openspec-opc/opencode-plugin",
  "version": "0.2.0",
  "description": "OpenCode runtime guard plugin for OpenSpec OPC workflows",
  "type": "module",
  "homepage": "https://github.com/lihaizhong/communism/tree/main/openspec-opc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lihaizhong/communism.git",
    "directory": "openspec-opc/plugins/opencode-spec-opc"
  },
  "bugs": {
    "url": "https://github.com/lihaizhong/communism/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@openspec-opc/guard-core": "0.2.0"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/*.test.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "!dist/*.test.js",
    "!dist/*.test.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "opencode",
    "openspec",
    "plugin",
    "guardrails",
    "workflow",
    "runtime-enforcement"
  ],
  "license": "MIT"
}
